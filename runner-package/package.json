{
  "name": "@drownek/plugwright",
  "version": "2.0.1",
  "description": "End-to-end testing framework for Paper/Spigot Minecraft plugins",
  "type": "module",
  "main": "dist/runner.js",
  "types": "dist/runner.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "prepublishOnly": "npm run build",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "minecraft",
    "paper",
    "spigot",
    "testing",
    "e2e",
    "mineflayer"
  ],
  "author": "drownek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Drownek/plugwright.git",
    "directory": "runner-package"
  },
  "homepage": "https://github.com/Drownek/plugwright#readme",
  "bugs": {
    "url": "https://github.com/Drownek/plugwright/issues"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "mineflayer": "^4.0.0",
    "picocolors": "^1.1.1",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "@types/source-map-support": "^0.5.10",
    "rimraf": "^6.1.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
